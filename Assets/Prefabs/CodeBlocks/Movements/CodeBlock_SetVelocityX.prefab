  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CodeBlock_SetVelocityX
  snappedPoint: {fileID: 0}
  <blockID>k__BackingField: SetVelocityX
  <displayColor>k__BackingField: {r: 0, g: 0.5882353, b: 1, a: 1}
  <MCPDescription>k__BackingField: Sets the horizontal velocity of the owning Rigidbody
    object to input, leaving vertical velocity unchanged. Only addable to a Rigidbody
    object, or a prefab whose origin is one. Use this for direct movement control;
    use AddVelocityX to accumulate onto existing velocity instead.
  rectTransform: {fileID: 3453263737707068497}
  <onFinish>k__BackingField: {fileID: 2315888032640577243}
  input: {fileID: 3243092156005557680}
